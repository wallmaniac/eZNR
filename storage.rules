rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Company-scoped files ────────────────────────────────────────────────
    // Users can only access files in company folders they belong to.
    // Admins (role=admin/superadmin) have access to all companies.
    match /companies/{companyId}/{allPaths=**} {
      allow read: if request.auth != null && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'] ||
        companyId in firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.companyIds
      );
      allow write: if request.auth != null && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'] ||
        companyId in firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.companyIds
      );
    }

    // ── Legacy fleet-documents path (backwards compat) ──────────────────────
    match /fleet-documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

