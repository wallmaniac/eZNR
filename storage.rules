rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Company-scoped files ────────────────────────────────────────────────
    // Any authenticated user can upload/download files within company folders.
    // Company-level access control is already enforced in-app via AuthContext
    // and in Firestore rules. Cross-service firestore.get() lookups from
    // Storage rules are unreliable and cause "storage/unauthorized" errors.
    match /companies/{companyId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ── Legacy fleet-documents path (backwards compat) ──────────────────────
    match /fleet-documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
