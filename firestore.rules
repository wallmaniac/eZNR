rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function belongsToCompany(companyId) {
      return isSignedIn() && companyId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyIds;
    }

    // 1) Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if request.auth.uid == userId || isAdmin();
    }

    // 2) Companies Collection
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 3) Global Catalog Data
    match /countries/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /counties/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /places/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /examTypes/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /certTypes/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /equipmentTypes/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /ppeTypes/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /fileTypes/{document} { allow read: if isSignedIn(); allow write: if false; }
    match /isznrDocTypes/{document} { allow read: if isSignedIn(); allow write: if false; }

    // 5) Questionnaire Sessions — public read by token, public write for status updates
    //    Admins can create sessions; public users can read & update (mark opened/completed)
    match /questionnaire_sessions/{sessionId} {
      // Anyone can read a session (needed to load the form via token)
      allow read: if true;
      // Authenticated admins can create sessions (when dispatching)
      allow create: if isSignedIn();
      // Public users can update status (mark opened, completed) — required for form submission
      allow update: if true;
    }

    // 6) Questionnaire Responses — public write (workers submit without login)
    //    Only authenticated users can read responses (admin results dashboard)
    match /questionnaire_responses/{responseId} {
      allow read: if isSignedIn();
      // Anyone can write a response (public form submission)
      allow write: if true;
    }

    // 7) Training Sessions — public read by token, public write for status updates
    //    Same pattern as questionnaire_sessions
    match /training_sessions/{sessionId} {
      // Anyone can read a session (worker opens the link)
      allow read: if true;
      // Authenticated admins can create sessions (when dispatching)
      allow create: if isSignedIn();
      // Public users can update status (mark opened, submit quiz answers)
      allow update: if true;
    }

    // 4) COMPANY-SCOPED DATA
    match /{collection}/{documentId} {
      allow read, write: if isSignedIn() && belongsToCompany(resource.data.companyId);
      allow create: if isSignedIn() && belongsToCompany(request.resource.data.companyId);
    }

  }
}
