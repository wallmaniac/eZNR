rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Check whether the signed-in user belongs to the given company
    function belongsToCompany(companyId) {
      return isSignedIn() && companyId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyIds;
    }

    // ── 1) Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if request.auth.uid == userId || isAdmin();
    }

    // ── 2) Companies ──────────────────────────────────────────────────────── 
    // Only members of a company (or admins) can read its document.
    // Previously "read: if isSignedIn()" exposed all company names/data to any user.
    match /companies/{companyId} {
      allow read: if isAdmin() || belongsToCompany(companyId);
      allow write: if isAdmin();
    }

    // ── 3) Global read-only catalogs ─────────────────────────────────────────
    match /countries/{document}        { allow read: if isSignedIn(); allow write: if false; }
    match /counties/{document}         { allow read: if isSignedIn(); allow write: if false; }
    match /places/{document}           { allow read: if isSignedIn(); allow write: if false; }
    match /examTypes/{document}        { allow read: if isSignedIn(); allow write: if false; }
    match /certTypes/{document}        { allow read: if isSignedIn(); allow write: if false; }
    match /equipmentTypes/{document}   { allow read: if isSignedIn(); allow write: if false; }
    match /ppeTypes/{document}         { allow read: if isSignedIn(); allow write: if false; }
    match /fileTypes/{document}        { allow read: if isSignedIn(); allow write: if false; }
    match /isznrDocTypes/{document}    { allow read: if isSignedIn(); allow write: if false; }

    // ── 4) Notification settings ──────────────────────────────────────────────
    // Documents are keyed by companyId (the document ID IS the company ID).
    // Only members and admins can read/write their company's settings.
    // Server-side (Admin SDK) always bypasses these rules.
    match /notif_settings/{companyId} {
      allow read, write: if isAdmin() || belongsToCompany(companyId);
    }

    // ── 5) Questionnaire sessions — public read/update, admin create ──────────
    match /questionnaire_sessions/{sessionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if true;   // workers mark sessions opened/completed
    }

    // ── 6) Questionnaire responses — public write, admin read ────────────────
    match /questionnaire_responses/{responseId} {
      allow read: if isSignedIn();
      allow write: if true;    // public form submission
    }

    // ── 7) Training sessions — same pattern as questionnaire sessions ─────────
    match /training_sessions/{sessionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if true;
    }

    // ── 8) Training responses — public write, admin read ─────────────────────
    match /training_responses/{responseId} {
      allow read: if isSignedIn();
      allow write: if true;
    }

    // ── 9) Company-scoped data (catch-all) ────────────────────────────────────
    // All other root-level collections (workers, certificates, PPE, etc.) must
    // have a companyId field. This prevents cross-company data access.
    match /{collection}/{documentId} {
      allow read:   if isSignedIn() && belongsToCompany(resource.data.companyId);
      allow update, delete: if isSignedIn() && belongsToCompany(resource.data.companyId);
      allow create: if isSignedIn() && belongsToCompany(request.resource.data.companyId);
    }

  }
}
